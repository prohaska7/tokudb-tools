Git branches

Tests

# run tests without valgrind
bash test.tokuft.bash runfastcheck=1

# run tests including some tests with valgrind's helgrind and drd
bash test.tokuft.bash runmemcheck=1

# run all tests with valgrind's memcheck
bash test.tokuft.bash runexpmemcheck=1

# run tests with the address sanitizer
# run tests with the thread sanitizer
bash test.tokudb.sanitize.bash

Speedups

# replace the fsync function with a fake version that just delays 100 microseconds.
export LD_PRELOAD=$HOME/bin/libfakefsync100.so
bash test.tokuft.bash

